# ============================================
# Configuration SGS Backend
# ============================================
# Copier ce fichier vers .env et ajuster les valeurs

# Serveur
NODE_ENV=development
PORT=5000

# Base de données MySQL (WAMP Server)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bdd_scolaire

# JWT - CHANGER CES VALEURS EN PRODUCTION !
JWT_SECRET=sgs_secret_key_2024_rdc_very_secure_CHANGE_ME
JWT_REFRESH_SECRET=sgs_refresh_secret_key_2024_rdc_CHANGE_ME
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

