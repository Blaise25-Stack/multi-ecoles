{
  "name": "sgs-backend",
  "version": "1.0.0",
  "description": "Backend API pour le Système de Gestion Scolaire",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "ts-node src/database/init.ts",
    "db:multitenant": "ts-node src/database/init-multitenant.ts",
    "db:check": "ts-node src/database/check-multitenant.ts",
    "db:setup": "npm run db:init && npm run db:multitenant",
    "db:clean": "ts-node src/database/clean-data.ts",
    "test:multitenant": "ts-node src/tests/multitenant.test.ts"
  },
  "keywords": ["school", "management", "api", "nodejs", "express", "mysql"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.4",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
